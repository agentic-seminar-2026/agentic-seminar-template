{
  "name": "founder-to-agentic-enterprise",
  "private": true,
  "version": "0.1.0",
  "description": "Helper scripts for the n8n-Cloud demo project bundled with the Governing the Agentic Enterprise seminar.",
  "type": "module",
  "scripts": {
    "validate": "tsx scripts/validate_company_pack.ts",
    "prepare:demo": "tsx scripts/prepare_demo_case.ts",
    "test:policy": "tsx scripts/test_policy_gate.ts",
    "preflight": "tsx scripts/preflight.ts",
    "push:workflow": "tsx scripts/n8n_push.ts",
