# OpenAI — required
OPENAI_API_KEY=sk-...

# Gmail outbound — controlled inboxes only in v1
GMAIL_FROM=demo@your-domain.example
GMAIL_REPLY_TO=demo@your-domain.example

# n8n Cloud webhook URL assigned to this workflow after activation
N8N_WEBHOOK_URL=https://<workspace>.app.n8n.cloud/webhook/founder-demo

# n8n REST API — used by `npm run push:workflow` to upload workflow JSON.
# For Cloud:   https://<workspace>.app.n8n.cloud/api/v1
# For local:   http://localhost:5678/api/v1   (see docker-compose.local.yml)
N8N_BASE_URL=https://<workspace>.app.n8n.cloud/api/v1
N8N_API_KEY=

# Optional default; trigger payload always wins
COMPANY_MODE=executive-education
